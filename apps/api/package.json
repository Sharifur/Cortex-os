{
  "name": "@cortex-os/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js build",
    "dev": "nest start --watch",
    "start": "node dist/src/main",
    "start:worker": "node dist/src/worker",
    "migrate": "node dist/src/migrate",
    "deploy": "node dist/src/migrate && node dist/src/main",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "ts-node -r tsconfig-paths/register src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/client-ses": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1039.0",
    "@fastify/multipart": "^8.3.1",
    "@google/generative-ai": "^0.24.1",
    "@maxmind/geoip2-node": "^6.3.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@paralleldrive/cuid2": "^2.2.2",
    "axios": "^1.15.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.31.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.29.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.42.0",
    "ioredis": "^5.4.2",
    "mammoth": "^1.12.0",
    "minio": "^8.0.3",
    "nestjs-pino": "^4.1.0",
    "openai": "^6.34.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pino-http": "^10.4.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.17.12",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/ua-parser-js": "^0.7.39",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.21.4",
    "pino-pretty": "^13.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
